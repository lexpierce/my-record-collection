{
  "name": "my_record_collection",
  "version": "1.0.0",
  "description": "Online record collection using Discogs API",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib __tests__ drizzle.config.ts next.config.ts vitest.config.ts vitest.setup.ts --ext .js,.jsx,.ts,.tsx",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.next\" \"#coverage\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.4",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1-alpha.0",
    "@typescript-eslint/parser": "^8.59.1-alpha.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "markdownlint-cli2": "^0.22.0",
    "msw": "^2.13.4",
    "postcss": "^8.5.10",
    "sass": "^1.99.0",
    "typescript-eslint": "^8.59.1-alpha.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "bun": "1.3.13"
  },
  "packageManager": "bun@1.3.13"
}
