{
  "name": "my_record_collection",
  "version": "1.1.1",
  "description": "Online record collection using Discogs API",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun astro dev",
    "build": "bun --bun astro build",
    "start": "HOST=0.0.0.0 bun ./dist/server/entry.mjs",
    "lint": "eslint src lib __tests__ drizzle.config.ts vitest.config.ts vitest.setup.ts --ext .js,.ts",
    "lint:md": "rumdl check .",
    "type-check": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.4",
    "@types/node": "^25.9.2",
    "astro": "^6.4.5",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.5.15",
    "sass": "^1.100.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
