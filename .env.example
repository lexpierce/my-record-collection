# Database connection string for Postgres 18
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/my_record_collection

# Discogs API configuration
# Get your personal access token at: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=your_discogs_personal_access_token_here
# User agent string — required by Discogs TOS (format: AppName/Version)
DISCOGS_USER_AGENT=MyRecordCollection/1.0
# Your Discogs username — required for collection sync
DISCOGS_USERNAME=your_discogs_username

# Shared secret required for all state-changing API calls (sync, refresh, delete).
# Requests must send: Authorization: Bearer <APP_AUTH_TOKEN>
# Generate one with: openssl rand -hex 32
APP_AUTH_TOKEN=replace_with_a_long_random_secret

# Runtime
NODE_ENV=production
